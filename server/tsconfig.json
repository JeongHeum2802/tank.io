{
  "compilerOptions": {
    "outDir": "./lib",
    "module": "commonjs",
    "lib": ["es6"],
    "target": "es2021",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
